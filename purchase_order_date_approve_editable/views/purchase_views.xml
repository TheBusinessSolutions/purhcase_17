<odoo>

    <record id="purchase_order_form" model="ir.ui.view">
        <field
            name="name"
        >purchase.order.form (in purchase_order_date_approve_editable)</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_approve']" position="attributes">
                <attribute name="readonly">state == 'done'</attribute>
                <attribute name="required">state == 'purchase'</attribute>
            </xpath>
        </field>
    </record>

</odoo>
